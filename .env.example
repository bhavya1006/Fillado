# Fillado Environment Variables
# Copy this file to .env and fill in your real values

# ============================================================
# Groq API (Required)
# Get your key at: https://console.groq.com
# ============================================================
# Single key (backward compatible)
GROQ_API_KEY=your_groq_api_key_here

# Multiple keys — round-robin rotation (optional, takes precedence over GROQ_API_KEY)
# GROQ_API_KEYS=gsk_abc123,gsk_def456,gsk_ghi789

# ============================================================
# Neo4j AuraDB (Required for live GraphRAG)
# Get a free instance at: https://neo4j.com/cloud/aura/
# ============================================================
NEO4J_URI=neo4j+s://your-instance-id.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# Multiple Neo4j instances — round-robin rotation (optional)
# Format per entry: bolt+s://host:7687|username|password  (pipe-separated)
# NEO4J_URIS=bolt+s://host1.databases.neo4j.io:7687|neo4j|pass1,bolt+s://host2.databases.neo4j.io:7687|neo4j|pass2

# ============================================================
# NewsData.io (Tier 1 ET News — Required for live news)
# Get a free key at: https://newsdata.io
# ============================================================
NEWSDATA_API_KEY=your_newsdata_api_key_here

# Multiple keys — round-robin rotation (optional)
# NEWSDATA_API_KEYS=pub_abc123,pub_def456

# ============================================================
# ArmorIQ AI Governance SDK
# Get credentials at: https://platform.armoriq.ai → Settings → API Keys
# ============================================================
ARMORIQ_API_KEY=your_armoriq_api_key_here
ARMORIQ_USER_ID=your_armoriq_user_id_here
ARMORIQ_AGENT_ID=your_armoriq_agent_id_here

# ============================================================
# ngrok public HTTPS tunnel URL
# Run: ngrok http 8000 and paste the Forwarding URL below.
# Update this every time you restart ngrok.
# ============================================================
NGROK_PUBLIC_URL=https://abc123def456.ngrok-free.app

# ============================================================
# App Configuration
# ============================================================
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
